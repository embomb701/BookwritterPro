# Copy to .env (or just export in your shell) and fill in.
#
# Pick an LLM backend with BOOKWRITER_LLM_PROVIDER (default: anthropic).
#
# API-key backends (per-token billing):
#   anthropic   Anthropic API             -> ANTHROPIC_API_KEY
#   openai      OpenAI API                -> OPENAI_API_KEY
#   openrouter  OpenRouter (OpenAI-compat)-> OPENROUTER_API_KEY
#   grok        Grok / xAI API (OpenAI-compat) -> GROK_API_KEY (or XAI_API_KEY)
#
# SUBSCRIPTION backends (shell out to a CLI you've signed in; no API key,
# no per-token billing):
#   claude-cli  `claude -p`     -> Claude Pro/Max login (needs the `claude` CLI)
#   codex       `codex exec`    -> ChatGPT Plus/Pro login (needs the OpenAI Codex CLI)
#   grok-cli    `grok`          -> Grok/X Premium login (needs a Grok CLI)
#   cli         <your command>  -> any signed-in CLI, set BOOKWRITER_CLI_CMD
BOOKWRITER_LLM_PROVIDER=anthropic

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                       # optional override

# --- OpenRouter ---
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Grok (xAI API, OpenAI-compatible) ---
# GROK_API_KEY=xai-...                    # or set XAI_API_KEY
# GROK_BASE_URL=https://api.x.ai/v1       # optional override

# --- Subscription CLIs ---
# claude-cli:
# BOOKWRITER_CLAUDE_BIN=                 # optional path to the claude binary
# codex (OpenAI ChatGPT subscription):
# BOOKWRITER_CODEX_CMD=codex exec -      # default: "-" reads the prompt from stdin
# grok-cli (Grok CLI — needs an xAI key, GROK_API_KEY, in its environment):
# BOOKWRITER_GROK_CMD=grok --prompt      # default; prompt is passed as an argument
# cli (any signed-in CLI):
# BOOKWRITER_CLI_CMD=                     # full command; prompt is piped on stdin
# BOOKWRITER_CLI_MODEL_FLAG=             # e.g. -m or --model, if the CLI takes one

# Model choice for non-Anthropic providers. Each maps a pipeline tier to a
# provider model id (overrides the built-in defaults). Optional.
# BOOKWRITER_MODEL_STRONG=gpt-4.1
# BOOKWRITER_MODEL_MID=gpt-4.1-mini
# BOOKWRITER_MODEL_CHEAP=gpt-4.1-nano

# ---------------------------------------------------------------------------
# Chapter images (the "Add chapter images" toggle in the Create AI Book modal).
# Defaults to Pixio; switch to any image API with BOOKWRITER_IMAGE_PROVIDER.
#   pixio   (default)  Pixio API          -> PIXIO_API_KEY
#   openai             OpenAI Images API  -> OPENAI_API_KEY
#   http               ANY image HTTP API -> BOOKWRITER_IMAGE_URL (+ auth/body/result)
# ---------------------------------------------------------------------------
# BOOKWRITER_IMAGE_PROVIDER=pixio
PIXIO_API_KEY=pxio_live_...
# BOOKWRITER_PIXIO_MODEL=               # optional; auto-discovered if unset
# PIXIO_IMAGE_MODEL=                    # legacy alias for BOOKWRITER_PIXIO_MODEL
# BOOKWRITER_IMAGE_ASPECT=3:2           # aspect ratio for chapter images

# openai images
# BOOKWRITER_OPENAI_IMAGE_MODEL=gpt-image-1
# BOOKWRITER_OPENAI_IMAGE_SIZE=1536x1024

# generic "http" image provider — point at any API:
# BOOKWRITER_IMAGE_URL=https://api.example.com/v1/images
# BOOKWRITER_IMAGE_AUTH=Bearer your-key
# BOOKWRITER_IMAGE_BODY={"prompt": "{prompt}", "size": "1024x1024"}
# BOOKWRITER_IMAGE_RESULT_PATH=data.0.url   # dot-path to the image URL in the response
# BOOKWRITER_IMAGE_RESULT_B64=              # set to 1 if that path holds base64, not a URL
